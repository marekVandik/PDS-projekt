# Bufferbloat trap topo conf
PDS_TOPO_NAME="Bufferbloat"

# BDP - 50mbps * 30ms = 187.5kB
# queue len 157.8kB / 1500 = 125
# much larger to induce bufferbloat -> 10000

# traffic to server
PDS_TOPO_RATE_S="50mbit"
PDS_TOPO_BURST_S="12kb"
PDS_TOPO_LIMIT_S="10000"

PDS_TOPO_DELAY_S="15ms"
PDS_TOPO_LOSS_S="0%"
PDS_TOPO_DUPL_S="0%"

# traffic to client
PDS_TOPO_RATE_C="50mbit"
PDS_TOPO_BURST_C="12kb"
PDS_TOPO_LIMIT_C="10000"

PDS_TOPO_DELAY_C="15ms"
PDS_TOPO_LOSS_C="0%"
PDS_TOPO_DUPL_C="0%"
