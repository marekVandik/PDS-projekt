# WiFi topology conf
PDS_TOPO_NAME="Wi-Fi"

# BDP - 400mbps * 6ms = 300kB
# queue len 300kB / 1500 = 200 -> 220

# traffic to server
PDS_TOPO_RATE_S="400mbit"
PDS_TOPO_BURST_S="300kb"
PDS_TOPO_LIMIT_S="220"

PDS_TOPO_DELAY_S="3ms"
PDS_TOPO_LOSS_S="3%"
PDS_TOPO_DUPL_S="0%"

# traffic to client
PDS_TOPO_RATE_C="400mbit"
PDS_TOPO_BURST_C="300kb"
PDS_TOPO_LIMIT_C="220"

PDS_TOPO_DELAY_C="3ms"
PDS_TOPO_LOSS_C="3%"
PDS_TOPO_DUPL_C="0%"
