# Starlink-like with high RTT (= GEO satellite, Starlink has much lower RTT around 50ms) topology conf
PDS_TOPO_NAME="GEO satellite"

# BDP - 80mbps * 400ms = 4MB
# queue len 4MB / 1500 = 2666.6 -> 3000

# traffic to server
PDS_TOPO_RATE_S="20mbit"
PDS_TOPO_BURST_S="12kb"
PDS_TOPO_LIMIT_S="750"

PDS_TOPO_DELAY_S="200ms 15ms"
PDS_TOPO_LOSS_S="0.5%"
PDS_TOPO_DUPL_S="0%"

# traffic to client
PDS_TOPO_RATE_C="80mbit"
PDS_TOPO_BURST_C="12kb"
PDS_TOPO_LIMIT_C="3000"

PDS_TOPO_DELAY_C="200ms 15ms"
PDS_TOPO_LOSS_C="0.5%"
PDS_TOPO_DUPL_C="0%"
