# baseline (no jitter, no bufferbloat etc...) topology conf
PDS_TOPO_NAME="Baseline"

# BDP - 40mbps * 20ms = 100kB
# queue len 100kB / 1500 = 66.67 -> 70

# traffic to server
PDS_TOPO_RATE_S="40mbit"
PDS_TOPO_BURST_S="12kb"
PDS_TOPO_LIMIT_S="100"

PDS_TOPO_DELAY_S="10ms"
PDS_TOPO_LOSS_S="0%"
PDS_TOPO_DUPL_S="0%"

# traffic to client
PDS_TOPO_RATE_C="40mbit"
PDS_TOPO_BURST_C="12kb"
PDS_TOPO_LIMIT_C="100"

PDS_TOPO_DELAY_C="10ms"
PDS_TOPO_LOSS_C="0%"
PDS_TOPO_DUPL_C="0%"
